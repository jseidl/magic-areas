"""Legacy light groups feature handler - compatible with existing flat config."""

import logging
from typing import Optional

import voluptuous as vol
from homeassistant.helpers import config_validation as cv

from custom_components.magic_areas.const import (
    AreaStates,
    BUILTIN_AREA_STATES,
    Features,
    LightGroupOptions,
    DEFAULT_LIGHT_GROUP_ACT_ON,
    LIGHT_GROUP_ACT_ON_OPTIONS,
    OPTIONS_LIGHT_GROUP,
    SelectorTranslationKeys,
)
from custom_components.magic_areas.config_flow.features import register_feature
from custom_components.magic_areas.config_flow.features.base import (
    FeatureHandler,
    StepResult,
)
from custom_components.magic_areas.config_flow.helpers import StateOptionsBuilder

_LOGGER = logging.getLogger(__name__)


@register_feature
class LightGroupsLegacyFeature(FeatureHandler):
    """
    Legacy light groups handler using flat 4-category config.

    Config format:
    {
        "overhead_lights": ["light.living_room_main"],
        "overhead_lights_states": ["occupied"],
        "overhead_lights_act_on": ["occupancy", "state"],
        "sleep_lights": [...],
        ... etc for accent, task
    }
    """

    # Define the 4 legacy categories with their display names
    CATEGORIES = [
        (LightGroupOptions.OVERHEAD.key, "Overhead Lights"),
        (LightGroupOptions.SLEEP.key, "Sleep Lights"),
        (LightGroupOptions.ACCENT.key, "Accent Lights"),
        (LightGroupOptions.TASK.key, "Task Lights"),
    ]

    @property
    def feature_id(self) -> str:
        return Features.LIGHT_GROUPS

    @property
    def feature_name(self) -> str:
        return "Light Groups"

    def get_initial_step(self) -> str:
        return "main"

    async def handle_step(self, step_id: str, user_input: Optional[dict]) -> StepResult:
        """Route to appropriate step."""
        if step_id == "main":
            return await self._step_main(user_input)
        elif step_id.startswith("config_"):
            category = step_id[7:]  # Remove "config_" prefix
            return await self._step_config_category(category, user_input)

        return await self._step_main(user_input)

    async def _step_main(self, user_input: Optional[dict]) -> StepResult:
        """Show menu of categories to configure."""
        if user_input is not None:
            selection = user_input["category"]
            if selection == "done":
                return StepResult(type="create_entry")
            return StepResult(type="form", step_id=f"config_{selection}")

        # Build menu with summaries for each category
        config = self.get_config()
        menu_options = {}

        for category_key, category_name in self.CATEGORIES:
            lights = config.get(category_key, [])
            count = len(lights)
            menu_options[category_key] = f"{category_name} ({count} lights)"

        menu_options["done"] = "✓ Done"

        # Count total configured lights
        total_lights = sum(len(config.get(cat, [])) for cat, _ in self.CATEGORIES)

        return StepResult(
            type="form",
            step_id="main",
            data_schema=vol.Schema({vol.Required("category"): vol.In(menu_options)}),
            description_placeholders={
                "total_lights": str(total_lights),
                "categories_configured": str(
                    sum(1 for cat, _ in self.CATEGORIES if config.get(cat))
                ),
            },
        )

    async def _step_config_category(
        self, category: str, user_input: Optional[dict]
    ) -> StepResult:
        """Configure a specific light category."""
        # Map category key to state/act_on keys
        states_key = f"{category}_states"
        act_on_key = f"{category}_act_on"

        # Get display name
        category_name = dict(self.CATEGORIES).get(
            category, category.replace("_", " ").title()
        )

        if user_input is not None:
            # Build the config update for this category
            config_update = {
                category: user_input["lights"],
                states_key: user_input["states"],
                act_on_key: user_input["act_on"],
            }

            # Merge with existing config
            current_config = self.get_config()
            current_config.update(config_update)

            return StepResult(type="create_entry", save_data=current_config)

        # Get available states
        secondary_states = self.area_options.get("secondary_states", {})
        available_states = StateOptionsBuilder.for_light_groups(
            secondary_states, exclude_dark=True
        )

        # Build schema
        config = self.get_config()
        lights = self.all_lights

        schema = vol.Schema(
            {
                vol.Optional(
                    "lights", default=config.get(category, [])
                ): cv.multi_select(lights) if len(lights) > 0 else vol.In([]),
                vol.Optional(
                    "states", default=config.get(states_key, ["occupied"])
                ): cv.multi_select(available_states),
                vol.Optional(
                    "act_on", default=config.get(act_on_key, DEFAULT_LIGHT_GROUP_ACT_ON)
                ): cv.multi_select(LIGHT_GROUP_ACT_ON_OPTIONS),
            }
        )

        return StepResult(
            type="form",
            step_id=f"config_{category}",
            data_schema=schema,
            description_placeholders={
                "category": category_name,
                "available_lights": str(len(lights)),
            },
        )

    def get_summary(self, config: dict) -> str:
        """Generate summary showing counts per category."""
        if not config:
            return "Not configured"

        parts = []
        for category_key, category_name in self.CATEGORIES:
            lights = config.get(category_key, [])
            if lights:
                parts.append(f"{category_name.split()[0]}: {len(lights)}")

        return ", ".join(parts) if parts else "Not configured"
